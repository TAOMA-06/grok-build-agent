{
  "name": "grok-build-desktop",
  "private": true,
  "version": "1.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "prepare:sidecar": "node scripts/prepare-sidecar.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run src/e2e",
    "benchmark:cache": "node scripts/cache-hit-gate.mjs",
    "benchmark:cache:test": "node scripts/cache-hit-gate.mjs --self-test",
    "check": "tsc --noEmit && vitest run && npm run benchmark:cache:test && npm run build",
    "release:check": "node scripts/release-safety-check.mjs",
    "tauri": "tauri",
    "app:dev": "GROK_BUILD_IN_PROCESS_HOST=1 tauri dev",
    "app:build": "APPLE_SIGNING_IDENTITY=- tauri build",
    "app:build:release": "node scripts/macos-release-preflight.mjs && tauri build",
    "app:build:universal": "node scripts/macos-release-preflight.mjs && tauri build --target universal-apple-darwin",
    "app:open": "open 'src-tauri/target/release/bundle/macos/Grok Build Desktop.app'"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tanstack/react-query": "^5.101.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^3.2.7",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
